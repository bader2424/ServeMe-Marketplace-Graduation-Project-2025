<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة التحكم - مزود الخدمة</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SERVE_ME_PROJECT.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/Admin/css/controlPanelForAdmin.css">
    <link rel="stylesheet" href="~/provider/css/controlPanalForServeiceProvider.css">

    <style>
        body {
            background-color: #f1f5f9;
            font-family: 'Cairo', sans-serif;
            margin: 0;
        }

        header {
            background-color: #0f172a;
            color: #fff;
            padding: 10px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 70px;
            position: fixed;
            top: 0;
            right: 0;
            left: 0;
            z-index: 1000;
            border-bottom: 1px solid #facc15;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.3);
        }

        .header-title {
            font-size: 20px;
            font-weight: bold;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .user-details span {
            font-size: 13px;
            color: #fcd34d;
            display: block;
        }

        .user-info img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #facc15;
        }

        .logout-btn {
            background-color: transparent;
            border: 1px solid #facc15;
            color: #facc15;
            padding: 6px 10px;
            border-radius: 5px;
            font-size: 14px;
            transition: 0.3s;
        }

            .logout-btn:hover {
                background-color: #facc15;
                color: #0f172a;
            }

        .sidebar {
            width: 250px;
            background-color: #0f172a;
            position: fixed;
            top: 0;
            right: 0;
            height: 100%;
            padding-top: 80px;
            border-left: 2px solid #facc15;
        }

            .sidebar ul {
                list-style: none;
                padding: 0;
                margin: 0;
            }

                .sidebar ul li a {
                    display: flex;
                    align-items: center;
                    gap: 10px;
                    padding: 14px 20px;
                    color: #d1d5db;
                    text-decoration: none;
                    font-size: 15px;
                    border-bottom: 1px solid #1e293b;
                    transition: all 0.3s ease;
                }

                    .sidebar ul li a:hover,
                    .sidebar ul li a.active {
                        background-color: #facc15;
                        color: #0f172a;
                        font-weight: bold;
                        border-right: 4px solid #facc15;
                    }

                    .sidebar ul li a i {
                        width: 20px;
                        text-align: center;
                    }

        .main-content {
            margin-right: 250px;
            margin-top: 70px;
            padding: 25px;
            background-color: #ffffff;
            min-height: calc(100vh - 70px);
            box-shadow: inset 0 0 10px rgba(0,0,0,0.05);
        }

        media (max-width: 768px) {
         .sidebar

        {
            width: 100%;
            height: auto;
            position: relative;
            border-left: none;
            border-top: 2px solid #facc15;
        }

        .main-content {
            margin-right: 0;
            margin-top: 140px;
            padding: 15px;
        }

        header {
            flex-direction: column;
            height: auto;
            padding: 15px;
            text-align: center;
        }

        .user-info {
            flex-direction: column;
            gap: 10px;
        }

        }
    </style>
</head>
<body>
    <header>
        <h1 class="header-title">لوحة التحكم - مزود الخدمة</h1>
        <div class="user-info">
            <div class="user-details">
                <span>مرحباً، مزود الخدمة</span>
                <span>provider@example.com</span>
            </div>
            <img src="~/Admin/images/geto.png" alt="مزود الخدمة">
            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                <button type="submit" class="logout-btn">
                    <i class="fas fa-sign-out-alt"></i>
                </button>
            </form>
        </div>
    </header>

    <div class="sidebar">
        <ul>
            <li><a asp-area="Provider" asp-controller="Home" asp-action="Staticts"><i class="fas fa-chart-bar"></i> الإحصائيات</a></li>
            <li><a asp-area="Provider" asp-controller="Service" asp-action="Index"><i class="fas fa-tools"></i> إدارة الخدمات</a></li>
            <li><a asp-area="Provider" asp-controller="Home" asp-action="Requests"><i class="fas fa-tasks"></i> إدارة الطلبات</a></li>
            <li><a asp-area="Provider" asp-controller="Home" asp-action="Comments"><i class="fas fa-comments"></i> التعليقات</a></li>
            <li><a asp-area="Provider" asp-controller="Account" asp-action="Profile"><i class="fas fa-user"></i> إدارة الحساب</a></li>
        </ul>
    </div>

    <div class="main-content">
        <main>
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Admin/js/controlPanelForAdmin.js"></script>
</body>
</html>
