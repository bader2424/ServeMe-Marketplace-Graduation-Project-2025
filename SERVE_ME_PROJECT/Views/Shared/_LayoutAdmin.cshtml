<!DOCTYPE html>
<html lang="en" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة التحكم - نظام إدارة الموقع</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SERVE_ME_PROJECT.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/~/Admin/css/all.min.css">
    <link rel="stylesheet" href="~/Admin/css/controlPanelForAdmin.css">
    <link rel="stylesheet" href="~/provider/css/controlPanalForServeiceProvider.css">

    <style>
        * {
            box-sizing: border-box;
        }

        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            font-family: Arial, sans-serif;
        }

        .topnav {
            width: 100%;
            background-color: #0c1a38;
            color: white;
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: fixed;
            top: 0;
            right: 0;
            left: 0;
            z-index: 1000;
        }

            .topnav h1 {
                font-size: 20px;
                margin: 0;
            }

        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .user-info img {
                width: 32px;
                height: 32px;
                border-radius: 50%;
            }

        .sidebar {
            width: 250px;
            position: fixed;
            top: 70px; /* ارتفاع الناف بار العلوي */
            right: 0;
            bottom: 0;
            background-color: #1c1f26;
            padding: 20px 10px;
            overflow-y: auto;
        }

            .sidebar ul {
                list-style: none;
                padding: 0;
            }

            .sidebar li {
                margin-bottom: 15px;
            }

            .sidebar a {
                color: white;
                text-decoration: none;
                display: block;
                padding: 10px;
                border-radius: 5px;
                transition: background 0.3s;
            }

                .sidebar a:hover {
                    background-color: #2c2f36;
                }

        .main-content {
            margin-right: 250px;
            padding: 100px 20px 20px; /* 100px لتفادي تداخل الناف بار */
        }
    </style>
</head>
<body>
    <!-- ✅ الناف بار العلوي خارج الهيدر حتى يغطي العرض بالكامل -->
    <div class="topnav">
        <h1>لوحة التحكم - نظام إدارة الموقع</h1>
        <div class="user-info">
            <span>مرحباً، مدير النظام</span>
            <img src="~/Admin/images/geto.png" alt="مدير النظام">
        </div>
    </div>

    <div class="sidebar">
        <ul>
            <li><a asp-area="AdminControlPanel" asp-controller="BlogModels" asp-action="Index"><i class="fas fa-layer-group"></i> الإحصائيات</a></li>
            <li><a asp-area="AdminControlPanel" asp-controller="BlogModels" asp-action="Index"><i class="fas fa-layer-group"></i> إدارة الحسابات</a></li>
            <li><a asp-area="AdminControlPanel" asp-controller="BlogModels" asp-action="Index"><i class="fas fa-layer-group"></i> إدارة الخدمات</a></li>
            <li><a asp-area="AdminControlPanel" asp-controller="BlogModels" asp-action="Index"><i class="fas fa-layer-group"></i> ادارة مزودي الخدمات</a></li>
            <li><a asp-area="AdminControlPanel" asp-controller="BlogModels" asp-action="Index"><i class="fas fa-layer-group"></i> ادارة المدن</a></li>
            <li><a asp-area="AdminControlPanel" asp-controller="BlogModels" asp-action="Index"><i class="fas fa-layer-group"></i> ادارة التصنيفات</a></li>
            <li><a asp-area="AdminControlPanel" asp-controller="BlogModels" asp-action="Index"><i class="fas fa-layer-group"></i> ادارة الاعلانات</a></li>
            <li><a asp-area="AdminControlPanel" asp-controller="BlogModels" asp-action="Index"><i class="fas fa-layer-group"></i> تواصل معنا</a></li>
            <li><a asp-area="AdminControlPanel" asp-controller="BlogModels" asp-action="Index"><i class="fas fa-layer-group"></i> ادارة المدونات</a></li>
            <li><a asp-area="AdminControlPanel" asp-controller="BlogModels" asp-action="Index"><i class="fas fa-layer-group"></i> اعدادات الموقع</a></li>
        </ul>
    </div>

    <div class="main-content">
        <main>
            @RenderBody()
        </main>
    </div>

    <footer></footer>
    <script src="~/Admin/js/controlPanelForAdmin.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
