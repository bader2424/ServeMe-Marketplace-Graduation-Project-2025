@model SERVE_ME_PROJECT.Models.ServiceProviderModel

@{
    ViewData["Title"] = "انضم كمزود خدمة";
    Layout = "_LayoutServeMe";
}

<style>
    .card-container {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 50px 15px;
        background: #f2f2f2;
        min-height: 100vh;
        direction: rtl;
        font-family: 'Tahoma', sans-serif;
    }

    .auth-card {
        display: flex;
        flex-direction: row-reverse;
        width: 100%;
        max-width: 900px;
        background: white;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .form-side {
        flex: 1;
        padding: 30px;
        background-color: #ffffff;
    }

    .info-side {
        flex: 1;
        background: linear-gradient(to left, #4C6DF0, #3a5bcc);
        color: white;
        padding: 40px 30px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        text-align: center;
    }

        .info-side h2 {
            font-size: 28px;
            margin-bottom: 15px;
        }

    .btn-outline-light {
        border-color: #fff;
        color: #fff;
    }

        .btn-outline-light:hover {
            background-color: #ffffff;
            color: #4C6DF0;
            border-color: #ffffff;
        }

    .form-group {
        margin-bottom: 15px;
    }

    label {
        font-weight: bold;
        margin-bottom: 5px;
    }

    .btn-primary {
        background-color: #4C6DF0;
        border-color: #4C6DF0;
    }

        .btn-primary:hover {
            background-color: #3a5bcc;
            border-color: #3a5bcc;
        }
</style>

<div class="card-container">
    <div class="auth-card">
        <!-- الجهة اليمنى: نموذج الانضمام -->
        <div class="form-side">
            <form asp-action="JoinAsProviderPost" method="post" enctype="multipart/form-data">
                <h2 class="mb-4 text-center">انضم كمزود خدمة</h2>
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group">
                    <label asp-for="NameShop">اسم المتجر</label>
                    <input asp-for="NameShop" class="form-control" required />
                    <span asp-validation-for="NameShop" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Description">وصف المتجر</label>
                    <input asp-for="Description" class="form-control" required />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="PhotoRecord">صورة السجل التجاري</label>
                    <input asp-for="PhotoRecord" type="file" class="form-control" required />
                    <span asp-validation-for="PhotoRecord" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Logo">شعار المتجر</label>
                    <input asp-for="Logo" type="file" class="form-control" required />
                    <span asp-validation-for="Logo" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="JoinDate">تاريخ الانضمام</label>
                    <input asp-for="JoinDate" type="date" class="form-control" required />
                    <span asp-validation-for="JoinDate" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 mt-3">انضمام</button>
            </form>
        </div>

        <!-- الجهة اليسرى: رسالة ترحيبية -->
        <div class="info-side">
            <h2>مرحبًا بك!</h2>
            <p>انضم كمزود خدمة وابدأ في عرض خدماتك الآن عبر منصتنا.</p>
            <a class="btn btn-outline-light mt-3" asp-area="Identity" asp-controller="Account" asp-action="Login">تسجيل الدخول</a>
        </div>
    </div>
</div>
