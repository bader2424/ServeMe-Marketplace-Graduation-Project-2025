@model SERVE_ME_PROJECT.Models.ContactUsModel

@{
    ViewData["Title"] = "Create";
    Layout = "_Layoutserveme";

}
<!-- Main CSS File -->
<link href="~/serveme/assets/css/main.css" rel="stylesheet">
<!-- Template Stylesheet -->
<link href="style.css" rel="stylesheet">
<link rel="stylesheet" href="sss.css">
<style>

    body, h1, h2, h3, h4, h5, h6, p, a, button, input, textarea {
        font-family: 'Cairo', sans-serif;
        margin: 0;
        padding: 0;
    }
</style>

<!-- Contact Section -->

<section id="contact" class="contact section" dir="rtl">

    <!-- Section Title -->
    <div class="container section-title" data-aos="fade-up">
        <h2>تواصل معنا </h2>
        <p>تواصل مع فريق المساعدة</p>
    </div><!-- End Section Title -->

    <div class="container" data-aos="fade-up" data-aos-delay="100">

        <div class="row gy-4">

            <div class="col-lg-6">

                <div class="row gy-4">
                    <div class="col-md-6">
                        <div class="info-item" data-aos="fade" data-aos-delay="200">
                            <i class="bi bi-geo-alt"></i>
                            <h3>العنوان</h3>
                            <p>حضرموت</p>
                            <p>المكلا-الغيل-الشحر </p>
                        </div>
                    </div><!-- End Info Item -->

                    <div class="col-md-6">
                        <div class="info-item" data-aos="fade" data-aos-delay="300">
                            <i class="bi bi-telephone"></i>
                            <h3>تلفون</h3>
                            <p>+1 5589 55488 55</p>
                            <p>+1 6678 254445 41</p>
                        </div>
                    </div><!-- End Info Item -->

                    <div class="col-md-6">
                        <div class="info-item" data-aos="fade" data-aos-delay="400">
                            <i class="bi bi-envelope"></i>
                            <h3>البريد الأكتروني</h3>
                            <p>ServeMe@gmail.com</p>

                        </div>
                    </div><!-- End Info Item -->

                    <div class="col-md-6">
                        <div class="info-item" data-aos="fade" data-aos-delay="500">
                            <i class="bi bi-clock"></i>
                            <h3>على مدار الساعة </h3>
                            <p>الاحد -السبت</p>
                            <p>9:00AM - 05:00PM</p>
                        </div>
                    </div><!-- End Info Item -->

                </div>

            </div>

            <div class="col-lg-6">
                <div class="info-item">
                    <form asp-action="Contact">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <div class="row gy-4">
                            <div class="col-md-6">
                                <span asp-validation-for="Name" class="text-danger">الاسم</span>
                                <input asp-for="Name" class="form-control" placeholder="SentDate" />
                            </div>
                            <div class="col-md-6">
                                <span asp-validation-for="Email" class="text-danger"> الايميل </span>
                                <input asp-for="Email" class="form-control" placeholder="SentDate" />
                            </div>
                            <div class="col-12">
                                <span asp-validation-for="Title" class="text-danger"> العنوان</span>
                                <input asp-for="Title" class="form-control" placeholder="SentDate" />
                            </div>
                            <div class="col-12">
                                <span asp-validation-for="Message" class="text-danger"> الرسالة</span>
                                <input asp-for="Message" class="form-control" placeholder="SentDate" />
                            </div>
                            <div class="col-12">
                                <input asp-for="SentDate" class="form-control" placeholder="SentDate" />
                                <span asp-validation-for="SentDate" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="form-group">
                            <input type="submit" value="ارسال" class="btn btn-primary" />
                        </div>
                    </form>

                </div>
            </div>

        </div>

     </div>
</section>
<!-- End Contact Form -->