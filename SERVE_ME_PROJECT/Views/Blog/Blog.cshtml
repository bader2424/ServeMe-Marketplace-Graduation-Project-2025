@model SERVE_ME_PROJECT.ViewModel.VmBlog

@{
    Layout = "_LayoutServeMe";
}

<section id="contact" class="contact section" style="background-color: #f8f9fa; padding: 50px 0;">
    <!-- Section Title -->
    <div class="container text-center"  style="margin-bottom:50px">
        <h2 style="color: #000000;">آخر الأخبار والتحديثات الخاصة بموقع أخذمني</h2>
    </div>
    <!-- End Section Title -->

    <div class="container">
        <div class="row">

            <div class="col-lg-12">

                <!-- Blog Posts Section -->
                <section id="blog-posts" class="blog-posts section">

                    <div class="container">

                        <div class="row gy-4">
                            @foreach (var blogs in Model.BlogModel)
                            {
                                <div class="col-md-6 col-lg-4">
                                    <!-- تم تعديل هنا إلى col-md-6 col-lg-4 للتقليص من عرض الكرت -->
                                    <div class="card border-light shadow-sm" style="border-radius: 15px; overflow: hidden; background-color: white; margin-bottom: 30px;">
                                        <!-- النصف العلوي من الكرت (عرض الصورة) -->
                                        <div class="post-img position-relative" style="height: 250px; overflow: hidden; border-top-left-radius: 15px; border-top-right-radius: 15px;">
                                            <img src="/img/@blogs.ImgUrl" alt="@blogs.Title" class="card-img-top" style="height: 100%; object-fit: cover; border-top-left-radius: 15px; border-top-right-radius: 15px;">

                                            <!-- شريط التاريخ في الزاوية السفلى على اليمين -->
                                            <div class="position-absolute bottom-0 end-0 m-3 p-2 bg-primary text-white rounded" style="font-size: 0.9rem;">
                                                @blogs.SentDate.ToString("dd MMM yyyy")
                                            </div>
                                        </div>

                                        <!-- النصف السفلي من الكرت (العنوان والمنطقة) -->
                                        <div class="card-body" style="border-bottom-left-radius: 15px; border-bottom-right-radius: 15px;">
                                            <h5 class="card-title" style="font-size: 1.25rem; font-weight: bold; color: #4C6DF0;">
                                                <a href="@Url.Action("Details_Blog", new { id = blogs.Id })" style="text-decoration: none; color: #4C6DF0;">
                                                    @blogs.Title
                                                </a>
                                            </h5>

                                            <!-- وصف قصير أو المنطقة -->
                                            <p class="card-text text-muted" style="font-size: 0.9rem;">
                                                @blogs.Content ?? "محتوى قصير من التدوينة يظهر هنا..."
                                            </p>

                                            <!-- رابط "أقرأ المزيد" -->
                                            <div class="d-flex justify-content-between align-items-center">
                                                <a href="@Url.Action("Details_Blog", new { id = blogs.Id })" class="btn btn-primary btn-sm">أقرأ المزيد</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div><!-- End blog posts list -->

                    </div>

                </section><!-- /Blog Posts Section -->
                <!-- Blog Pagination Section -->
                <section id="blog-pagination" class="blog-pagination section">
                    <div class="container">
                        <div class="d-flex justify-content-center">
                            <ul class="pagination">
                                <li class="page-item"><a class="page-link" href="#"><i class="bi bi-chevron-left"></i></a></li>
                                <li class="page-item"><a class="page-link" href="#">1</a></li>
                                <li class="page-item"><a class="page-link" href="#">2</a></li>
                                <li class="page-item"><a class="page-link" href="#">3</a></li>
                                <li class="page-item"><a class="page-link" href="#">4</a></li>
                                <li class="page-item"><a class="page-link" href="#">...</a></li>
                                <li class="page-item"><a class="page-link" href="#">10</a></li>
                                <li class="page-item"><a class="page-link" href="#"><i class="bi bi-chevron-right"></i></a></li>
                            </ul>
                        </div>
                    </div>
                </section><!-- /Blog Pagination Section -->

            </div>

        </div>
    </div>
</section>
