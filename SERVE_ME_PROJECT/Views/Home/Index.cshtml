<!-- Clients Section -->
<section id="clients" class="clients section">

    <!-- Section Title -->
    <div class="container section-title" data-aos="fade-up">
        <h2>مزودي الخدمة</h2>
        <p>مزودي منصة أخدمني<br></p>
    </div><!-- End Section Title -->

    <div class="container" data-aos="fade-up" data-aos-delay="100">

        <div class="swiper init-swiper">
             <script type="application/json" class="swiper-config">
                {
                "loop": true,
                "speed": 600,
                "autoplay": {
                "delay": 5000
                },
                "slidesPerView": "auto",
                "pagination": {
                "el": ".swiper-pagination",
                "type": "bullets",
                "clickable": true
                },
                "breakpoints": {
                "320": {
                "slidesPerView": 2,
                "spaceBetween": 40
                },
                "480": {
                "slidesPerView": 3,
                "spaceBetween": 60
                },
                "640": {
                "slidesPerView": 4,
                "spaceBetween": 80
                },
                "992": {
                "slidesPerView": 6,
                "spaceBetween": 120
                }
                }
                }
            </script> 

            <div class="swiper-wrapper align-items-center">
                @foreach(var servprov in Model.ServiceProviderModel)
                {
                    <div class="swiper-slide">
                        <img src="~/img/@servprov.Logo" class="img-fluid" alt="@servprov.NameShop" style="height:100px">
                        <img src="~/img/755672cf-3549-42a7-8c09-589c9fc4e587.jpg" class="img-fluid" alt="" style="height:100px">
                     </div>
                }
            </div>
            <div class="swiper-pagination"></div>
        </div>

    </div>

</section><!-- /Clients Section -->
<!-- Recent Posts Section -->
<section id="recent-posts" class="recent-posts section">

    <!-- Section Title -->
    <div class="container section-title" data-aos="fade-up">
        <h2>المدونة</h2>
        <p>مدونات منصة أخدمني</p>
    </div><!-- End Section Title -->

    <div class="container">
        <div class="row gy-5">
            @foreach (var blog in Model.BlogModel)
            {
                <div class="col-xl-4 col-md-6">
                    <div class="post-item position-relative h-100" data-aos="fade-up" data-aos-delay="100">

                        <div class="post-img position-relative overflow-hidden">
                            <img src="/img/@blog.ImgUrl" class="img-fluid" alt="" style="height:200px">
                            <span class="post-date">@blog.SentDate.ToString("yyyy/MM/dd")</span>
                        </div>

                        <div class="post-content d-flex flex-column" style="padding: 10px 10px" dir="rtl">
                            <h3 class="post-title">@blog.Title</h3>
                        </div>

                        <div style="padding: 20px 20px">
                            <a href="@Url.Action("Details_Blog", new { id = blog.Id })" class="btn btn-danger">
                                <span>أقرأ المزيد</span>
                                <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>

                    </div>
                </div>
                <!-- End post item -->
            }
        </div>

        <!-- زر عرض الكل -->
        <div class="text-center mt-4">
            <a asp-action="Blog" asp-controller="Blog" class="btn btn-outline-primary">
                عرض جميع التدوينات <i class="bi bi-journal-text"></i>
            </a>
        </div>

    </div>

</section>
<!-- /Recent Posts Section -->
