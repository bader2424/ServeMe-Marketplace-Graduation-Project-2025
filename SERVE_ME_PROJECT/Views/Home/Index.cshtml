@using SERVE_ME_PROJECT.ViewModel;
@model VmLandng
@{
    Layout = "_LayoutServeMe";
}

<!-- Hero Section -->
<section id="hero" class="hero section">

    <div class="container">
        <div class="row gy-4">
            @foreach (var gental in Model.GeneralSettingsModel)
            {
                <div class="col-lg-6 order-2 order-lg-1 d-flex flex-column justify-content-center">
                    <h1 style="text-align: right; direction: rtl;" data-aos="fade-up"> @gental.SiteName</h1>
                    <br />
                    <p style="text-align: right; direction: rtl;" data-aos="fade-up" data-aos-delay="100">@gental.SiteDescription</p>

                    <div class="d-flex flex-column flex-md-row" data-aos="fade-up" data-aos-delay="200">
                        @if (!User.Identity.IsAuthenticated)
                        {
                            <a asp-area="Identity" asp-page="/Account/Register" class="btn-get-started">انضم الينا<i class="bi bi-arrow-right"></i></a>
                        }
                    </div>
                </div>
                <div class="col-lg-6 order-1 order-lg-2 hero-img" data-aos="zoom-out">
                    <img src="/img/@gental.SiteLogo" class="img-fluid animated" alt="servmeLogo" style="height:200px">
                </div>
            }            

        </div>
    </div>

</section><!-- /Hero Section -->

<!-- About Section -->
<section id="about" class="about section">

    <div class="container" data-aos="fade-up">
        <div class="row gx-0">

            <div class="col-lg-6 d-flex flex-column justify-content-center" data-aos="fade-up" data-aos-delay="200">
                <div class="content">
                    <h3 style="text-align: right; direction: rtl;" >من نحن</h3>
                    <h2 style="text-align: right; direction: rtl;" >
                        أخدمني منصة خدمات اجتماعية

                    </h2>
                    <p style="text-align: right; direction: rtl;" >
                        أخدمني هي منصه مختصه في ربط مزودي الخدمه مع المستهلك لنتمكن من خدمتك بكافة التفاصيل المطلوبة حيث يمكن للمستهلك تصفح جميع الخدمات المقدمة لتنظيم مناسبتة والتواصل مع مقدمي الخدمة بكل سهولة  بمكان واحد مع خيارات الخدمات المتعددة

                    </p>

                    <h2 style="text-align: right; direction: rtl;" >
                        رؤيتنا
                    </h2>  


                    <p style="text-align: right; direction: rtl;" >
                        أن نكون من المبادرين في اتخاذ القرارات لمحافظة حضرموت ، عند تقديم منصه مختصه بربط مزودي الخدمات بالعملاء دون التأثير سلبًا على الجودة العالية أو الفائدة المقدَّمة لعملائنا


                    </p>

                </div>
            </div>

            <div class="col-lg-6 d-flex align-items-center" data-aos="zoom-out" data-aos-delay="200">
                <img src="~/serveme/assets/img/logo2.png" class="img-fluid" alt="">
            </div>

        </div>
    </div>

</section><!-- /About Section -->

<!-- Values Section -->
<section id="values" class="values section">

    <!-- Section Title -->
    <div class="container section-title" data-aos="fade-up">
        <h2>خدماتنا</h2>
        <p>  خدمات  منصة أخدمني<br></p>
    </div><!-- End Section Title -->

    <div class="container">

        <div class="row gy-4">

            <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
                <div class="card">
                    <img src="~/serveme/assets/img/sp.jpg" class="img-fluid" alt="">
                    <h3>الأتفاق مع مزودي الخدمة</h3>
                </div>
            </div><!-- End Card Item -->

            <div class="col-lg-4" data-aos="fade-up" data-aos-delay="200">
                <div class="card">
                    <img src="~/serveme/assets/img/sw.jpg" class="img-fluid" alt="">
                    <h3>تنسيق حفلات الأعراس والتخرج </h3>
                </div>
            </div><!-- End Card Item -->

            <div class="col-lg-4" data-aos="fade-up" data-aos-delay="300">
                <div class="card">
                    <img src="~/serveme/assets/img/swidimg.jpg" class="img-fluid" alt="">
                    <h3> التخطيط للسياحة والترفيه</h3>
                </div>
            </div><!-- End Card Item -->
            <!-- Portfolio Section -->
</section><!-- /Values Section -->

