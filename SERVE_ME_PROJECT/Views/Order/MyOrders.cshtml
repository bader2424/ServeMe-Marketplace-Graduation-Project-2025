
@model SERVE_ME_PROJECT.ViewModel.VmMyOrders

@{
    ViewData["Title"] = "طلباتي";
    Layout = "_LayoutServeMe";
}

<div class="container py-5">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">طلباتي</h3>
                </div>
                <div class="card-body">
                    @if (Model.Orders.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>رقم الطلب</th>
                                        <th>الخدمة</th>
                                        <th>المبلغ</th>
                                        <th>التاريخ</th>
                                        <th>الحالة</th>
                                        <th>الإجراءات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model.Orders)
                                    {
                                        <tr>
                                            <td>#@order.Id</td>
                                            <td>@order.Service?.Name</td>
                                            <td>@order.Price.ToString("N2") ر.ي</td>
                                            <td>@order.OrderDate.ToString("yyyy/MM/dd")</td>
                                            <td>
                                                <span class="badge @GetStatusBadge(order.OrderStat?.Name)">
                                                    @order.OrderStat?.Name
                                                </span>
                                            </td>
                                            <td>
                                                <a asp-controller="Order" asp-action="Details" asp-route-id="@order.ServiceId"
                                                   class="btn btn-sm btn-outline-primary">
                                                    <i class="fas fa-eye"></i> عرض الخدمة
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <nav aria-label="Page navigation" class="mt-4">
                            <ul class="pagination justify-content-center">
                                @if (Model.CurrentPage > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link" asp-action="MyOrders" asp-route-page="@(Model.CurrentPage - 1)">
                                            السابق
                                        </a>
                                    </li>
                                }

                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link" asp-action="MyOrders" asp-route-page="@i">@i</a>
                                    </li>
                                }

                                @if (Model.CurrentPage < Model.TotalPages)
                                {
                                    <li class="page-item">
                                        <a class="page-link" asp-action="MyOrders" asp-route-page="@(Model.CurrentPage + 1)">
                                            التالي
                                        </a>
                                    </li>
                                }
                            </ul>
                        </nav>
                    }
                    else
                    {
                        <div class="alert alert-info text-center">
                            <i class="fas fa-info-circle"></i> لا توجد لديك أي طلبات حالياً
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    string GetStatusBadge(string status)
    {
        return status switch
        {
            "معلق" => "bg-warning",
            "مقبول" => "bg-success",
            "مرفوض" => "bg-danger",
            "مكتمل" => "bg-info",
            _ => "bg-secondary"
        };
    }
}