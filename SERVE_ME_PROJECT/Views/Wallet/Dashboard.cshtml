@model SERVE_ME_PROJECT.ViewModel.VmWalletDashboard

@{
    ViewData["Title"] = "لوحة تحكم المحفظة";
    Layout = "_LayoutServeMe";
}

<div class="wallet-dashboard">
    <div class="row">
        <div class="col-md-8">
            <div class="card balance-card mb-4">
                <div class="card-body">
                    <h2 class="card-title">رصيدك الحالي</h2>
                    <div class="balance-amount">@Model.Balance.ToString("N2") ر.ي</div>
                    <div class="actions mt-4">
                        <a asp-action="RequestDeposit" class="btn btn-success me-2">
                            <i class="fas fa-plus-circle"></i> إيداع
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card status-card mb-4">
                <div class="card-body">
                    <h3 class="card-title">حالة الطلبات</h3>
                    <div class="status-item">
                        <span class="status-label">طلبات إيداع قيد المراجعة:</span>
                        <span class="status-value">@Model.PendingDeposits</span>
                    </div>
                    <div class="status-item">
                        <span class="status-label">طلبات سحب قيد المراجعة:</span>
                        <span class="status-value">@Model.PendingWithdrawals</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card transactions-card">
        <div class="card-header">
            <h3>آخر الحركات</h3>
            <a asp-action="TransactionHistory" class="view-all">عرض الكل</a>
        </div>
        <div class="card-body">
            @if (Model.RecentTransactions.Any())
            {
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>التاريخ</th>
                                <th>النوع</th>
                                <th>المبلغ</th>
                                <th>الوصف</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var transaction in Model.RecentTransactions)
                            {
                                <tr>
                                    <td>@transaction.TransactionDate.ToString("yyyy/MM/dd HH:mm")</td>
                                    <td>@transaction.TransactionType.Name</td>
                                    <td class="@(transaction.TransactionType.IsCredit ? "text-success" : "text-danger")">
                                        @(transaction.TransactionType.IsCredit ? "+" : "-") @transaction.Amount.ToString("N2") ر.ي
                                    <td>@transaction.Description</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">لا توجد حركات حديثة</div>
            }
        </div>
    </div>
</div>

@section Styles {
    <style>
        .wallet-dashboard {
            padding: 20px;
        }

        .balance-card {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        .balance-amount {
            font-size: 2.5rem;
            font-weight: bold;
            color: #2c3e50;
        }

        .status-card {
            background: #ffffff;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        .status-item {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid #eee;
        }

        .transactions-card {
            margin-top: 20px;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        .view-all {
            color: #3498db;
            text-decoration: none;
            font-weight: normal;
        }
    </style>
}