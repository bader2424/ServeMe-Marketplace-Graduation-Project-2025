@model List<SERVE_ME_PROJECT.Models.ServiceModel>
@{
    ViewData["Title"] = "خدماتي";
    Layout = "_LayoutProvid";
}

<h2>خدماتي</h2>
<a href="@Url.Action("Create")" class="btn btn-primary mb-3">إضافة خدمة جديدة</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>العنوان</th>
            <th>التصنيف</th>
            <th>المدينة</th>
            <th>الحالة</th>
            <th>الإجراءات</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Category.Name</td>
                <td>@item.City.Name</td>
                <td>
                    @if (item.IsApproved)
                    {
                        <span class="badge bg-success">منشورة</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">قيد المراجعة</span>
                    }
                </td>
                <td>
                    <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-info btn-sm">تفاصيل</a>
                    <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-primary btn-sm">تعديل</a>
                </td>
            </tr>
        }
    </tbody>
</table>
