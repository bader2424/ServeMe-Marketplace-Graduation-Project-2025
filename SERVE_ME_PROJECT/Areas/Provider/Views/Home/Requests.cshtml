@{
    Layout = "_LayoutProvid";

}

<!-- Section: الطلبات -->
<section class="requests-section">
    <h2>الطلبات</h2>
    <label for="filter-status">تصفية الطلبات حسب الحالة:</label>
    <select id="filter-status" onchange="filterRequests()">
        <option value="all">الكل</option>
        <option value="success">ناجحة</option>
        <option value="waiting">في الانتظار</option>
        <option value="fail">فاشلة</option>
    </select>
    <table class="requests-table">
        <thead>
            <tr>
                <th>رقم الطلب</th>
                <th>اسم العميل</th>
                <th>الحالة</th>
                <th>التاريخ</th>
                <th>الإجراءات</th>
            </tr>
        </thead>
        <tbody id="requests-body">
            <tr data-status="success">
