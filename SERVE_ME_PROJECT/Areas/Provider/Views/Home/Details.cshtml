@model ServiceModel
@{
    ViewData["Title"] = "تفاصيل الخدمة";
    Layout = "_LayoutProvid";
}

<div class="container">
    <h2 class="text-center my-4">@Model.Name</h2>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="mb-3">
                <strong>الوصف:</strong>
                <p>@Model.Description</p>
            </div>

            <div class="mb-3">
                <strong>المدينة:</strong> @Model.City.Name
            </div>

            <div class="mb-3">
                <strong>التصنيف:</strong> @Model.Category.Name
            </div>

            <div class="mb-3">
                <strong>نوع الخدمة:</strong> @Model.TypeService.Name
            </div>
        </div>

        <div class="col-md-6">
            <div class="row">
                @foreach (var img in Model.Images)
                {
                    <div class="col-md-4 mb-3">
                        <div class="image-container">
                            <img src="@img.ImagePath" class="img-fluid rounded w-100 h-100 object-fit-cover" />
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="text-center">
        <a asp-action="MyServices" class="btn btn-secondary">رجوع</a>
    </div>
</div>
