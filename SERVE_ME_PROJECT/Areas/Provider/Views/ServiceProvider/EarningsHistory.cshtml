@model SERVE_ME_PROJECT.ViewModel.VmProviderEarningsHistory

@{
    ViewData["Title"] = "سجل الأرباح";
    Layout = "_LayoutProvid";
}

<div class="provider-earnings-history">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <div class="d-flex justify-content-between align-items-center">
                <h3>سجل الأرباح</h3>
                <div class="total-earnings">
                    إجمالي الأرباح: <span>@Model.TotalEarnings.ToString("N2") ر.ي</span>
                </div>
            </div>
        </div>
        <div class="card-body">
            @if (Model.Earnings.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>التاريخ</th>
                                <th>المبلغ</th>
                                <th>الخدمة</th>
                                <th>العميل</th>
                                <th>الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var earning in Model.Earnings)
                            {
                                <tr>
                                    <td>@earning.TransactionDate.ToString("yyyy/MM/dd")</td>
                                    <td class="text-success">+ @earning.Amount.ToString("N2") ر.ي</td>
                                    <td>
                                        @if (earning.Order?.Service != null)
                                        {
                                            <a asp-controller="Services" asp-action="Details" asp-route-id="@earning.Order.Service.Id">
                                                @earning.Order.Service.Name
                                            </a>
                                        }
                                    </td>
                                    <td>
                                        @if (earning.Order?.User != null)
                                        {
                                            @earning.Order.User.FullName
                                        }
                                    </td>
                                    <td>
                                        <a asp-action="TransactionDetails" asp-route-id="@earning.TransactionId"
                                           class="btn btn-sm btn-outline-primary">
                                            التفاصيل
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <nav aria-label="Page navigation" class="mt-4">
                    <ul class="pagination justify-content-center">
                        @if (Model.CurrentPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="EarningsHistory" asp-route-page="@(Model.CurrentPage - 1)">
                                    السابق
                                </a>
                            </li>
                        }

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="EarningsHistory" asp-route-page="@i">@i</a>
                            </li>
                        }

                        @if (Model.CurrentPage < Model.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="EarningsHistory" asp-route-page="@(Model.CurrentPage + 1)">
                                    التالي
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle"></i> لا توجد أرباح مسجلة
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <style>
        .provider-earnings-history {
            padding: 20px;
        }

        .total-earnings {
            font-size: 1.1rem;
        }

            .total-earnings span {
                font-weight: bold;
                color: #f8f9fa;
            }
    </style>
}