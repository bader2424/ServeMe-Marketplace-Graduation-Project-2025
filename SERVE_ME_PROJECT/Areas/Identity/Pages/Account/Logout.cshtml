@page
@model LogoutModel
@{
    ViewData["Title"] = "تسجيل الخروج";
    Layout = "~/Views/Shared/_LayoutServeMe.cshtml"; // تأكد أن التخطيط الرئيسي مرفق
}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <h2 class="card-title mb-4">@ViewData["Title"]</h2>

                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <p class="text-muted mb-3">هل ترغب بتسجيل الخروج من حسابك؟</p>
                        <form asp-area="Identity" asp-page="/Account/Logout"
                              asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                            <button type="submit" class="btn btn-danger px-4">
                                تسجيل الخروج
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-success mt-3" role="alert">
                            تم تسجيل الخروج بنجاح. شكرًا لاستخدامك التطبيق.
                        </div>
                        <a href="/" class="btn btn-outline-primary mt-2">العودة إلى الصفحة الرئيسية</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
