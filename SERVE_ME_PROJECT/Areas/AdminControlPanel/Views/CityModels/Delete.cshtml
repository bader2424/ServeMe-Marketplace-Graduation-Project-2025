@model SERVE_ME_PROJECT.Models.CityModel

@{
    ViewData["Title"] = "Delete";
    Layout = "_LayoutAdmin";

}

<h1>حذف </h1>

<h3>هل انت متأكد من حذف هذه المدينة ؟ </h3>
<div>
     <hr />
    <dl class="row">
        <dt class = "col-sm-2">اسم المدينة        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
    </dl>


    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="حذف " class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-outline-primary">العودة للقائمة </a>
    </form>
</div>
