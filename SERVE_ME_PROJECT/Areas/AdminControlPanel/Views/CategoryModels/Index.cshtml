@model IEnumerable<SERVE_ME_PROJECT.Models.CategoryModel>

@{
    ViewData["Title"] = "Index";
    Layout = "_LayoutAdmin";

}

<h1> عرض تصنيفات الخدمات</h1>

<p>
    <a asp-action="Create" class="btn btn-outline-primary"> إضافة جديد </a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>رقم التصنيف             </th>
            <th>التصنيف             </th>
            
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Id)
                </td>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                    <a asp-action="Edit" class="status-btn success" asp-route-id="@item.Id">تعديل </a> |
                    <a asp-action="Details" class="status-btn waiting" asp-route-id="@item.Id">التفاصيلى</a> |
                    <a asp-action="Delete" class="status-btn fail" asp-route-id="@item.Id">حذف </a>
            </td>
        </tr>
}
    </tbody>
</table>