@model SERVE_ME_PROJECT.ViewModel.VmAdminWithdrawals

@{
    ViewData["Title"] = "إدارة طلبات السحب";
    Layout = "_LayoutAdmin";
}

<div class="admin-manage-withdrawals">
    <div class="card">
        <div class="card-header bg-dark text-white">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="mb-0">إدارة طلبات السحب - @Model.CurrentStatus</h4>
                <div class="dropdown">
                    <button class="btn btn-outline-light dropdown-toggle" type="button" id="statusDropdown" data-bs-toggle="dropdown">
                        تغيير الحالة
                    </button>
                    <ul class="dropdown-menu">
                        @foreach (var status in Model.StatusList)
                        {
                            <li>
                                <a class="dropdown-item @(status == Model.CurrentStatus ? "active" : "")"
                                   asp-action="ManageWithdrawals" asp-route-status="@status">
                                    @status
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
        <div class="card-body">
            @if (Model.Withdrawals.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>رقم الطلب</th>
                                <th>مقدم الخدمة</th>
                                <th>المبلغ</th>
                                <th>تاريخ الطلب</th>
                                <th>الحالة</th>
                                <th>الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var withdrawal in Model.Withdrawals)
                            {
                                <tr>
                                    <td>#@withdrawal.WithdrawalRequestId</td>
                                    <td>@withdrawal.Provider?.FullName</td>
                                    <td>@withdrawal.Amount.ToString("N2") ر.ي</td>
                                    <td>@withdrawal.RequestDate.ToString("yyyy/MM/dd")</td>
                                    <td>
                                        <span class="badge @GetStatusBadge(withdrawal.Status)">
                                            @withdrawal.Status
                                        </span>
                                    </td>
                                    <td>
                                        <a asp-action="WithdrawalDetails" asp-route-id="@withdrawal.WithdrawalRequestId"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i> تفاصيل
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <nav aria-label="Page navigation" class="mt-4">
                    <ul class="pagination justify-content-center">
                        @if (Model.CurrentPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="ManageWithdrawals"
                                   asp-route-status="@Model.CurrentStatus"
                                   asp-route-page="@(Model.CurrentPage - 1)">
                                    السابق
                                </a>
                            </li>
                        }

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="ManageWithdrawals"
                                   asp-route-status="@Model.CurrentStatus"
                                   asp-route-page="@i">@i</a>
                            </li>
                        }

                        @if (Model.CurrentPage < Model.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="ManageWithdrawals"
                                   asp-route-status="@Model.CurrentStatus"
                                   asp-route-page="@(Model.CurrentPage + 1)">
                                    التالي
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle"></i> لا توجد طلبات سحب بحالة "@Model.CurrentStatus"
                </div>
            }
        </div>
    </div>
</div>

@functions {
    string GetStatusBadge(string status)
    {
        return status switch
        {
            "Pending" => "bg-warning",
            "Approved" => "bg-info",
            "Completed" => "bg-success",
            "Rejected" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}

@section Styles {
    <style>
        .admin-manage-withdrawals {
            padding: 20px;
        }
    </style>
}