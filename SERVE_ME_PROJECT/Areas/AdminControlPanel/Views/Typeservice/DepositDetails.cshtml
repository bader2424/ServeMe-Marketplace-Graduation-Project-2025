@model SERVE_ME_PROJECT.Models.DepositRequest

@{
    ViewData["Title"] = "تفاصيل طلب الإيداع";
    Layout = "_LayoutAdmin";
}

<div class="admin-deposit-details">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h4>تفاصيل طلب الإيداع #@Model.DepositRequestId</h4>
        </div>
        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-6">
                    <div class="info-item">
                        <h6 class="text-muted">المستخدم:</h6>
                        <p>@Model.User?.FullName</p>
                    </div>
                    <div class="info-item">
                        <h6 class="text-muted">المبلغ:</h6>
                        <p class="text-success fw-bold">@Model.Amount.ToString("N2") ر.ي</p>
                    </div>
                    <div class="info-item">
                        <h6 class="text-muted">حالة الطلب:</h6>
                        <span class="badge @GetStatusBadge(Model.Status)">
                            @Model.Status
                        </span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="info-item">
                        <h6 class="text-muted">تاريخ الطلب:</h6>
                        <p>@Model.RequestDate.ToString("yyyy/MM/dd HH:mm")</p>
                    </div>
                    <div class="info-item">
                        <h6 class="text-muted">رقم المرجع:</h6>
                        <p>@Model.TransactionReference</p>
                    </div>
                </div>
            </div>

            <div class="deposit-proof mb-4">
                <h5 class="border-bottom pb-2 mb-3">إثبات الإيداع</h5>
                <div class="text-center">
                    <img src="@Model.DepositProofImage" class="img-fluid rounded border" style="max-height: 400px;"
                         alt="إثبات الإيداع لطلب #@Model.DepositRequestId">
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.AdminNotes))
            {
                <div class="admin-notes alert alert-warning">
                    <h5>ملاحظات المشرف:</h5>
                    <p class="mb-0">@Model.AdminNotes</p>
                </div>
            }

            @if (Model.Status == "Pending")
            {
                <div class="actions mt-4">
                    <form asp-action="ProcessDeposit" method="post">
                        <input type="hidden" name="id" value="@Model.DepositRequestId" />

                        <div class="form-group mb-3">
                            <label for="adminNotes" class="form-label">ملاحظات المشرف</label>
                            <textarea name="adminNotes" id="adminNotes" class="form-control" rows="3"></textarea>
                        </div>

                        <div class="d-flex justify-content-between">
                            <button type="submit" name="action" value="reject" class="btn btn-danger">
                                <i class="fas fa-times"></i> رفض الطلب
                            </button>
                            <button type="submit" name="action" value="approve" class="btn btn-success">
                                <i class="fas fa-check"></i> قبول الطلب
                            </button>
                        </div>
                    </form>
                </div>
            }
            else
            {
                <div class="processed-info alert alert-info mt-4">
                    <h5>معلومات المعالجة</h5>
                    <p class="mb-1"><strong>تاريخ المعالجة:</strong> @Model.ProcessedDate?.ToString("yyyy/MM/dd HH:mm")</p>
                    @if (!string.IsNullOrEmpty(Model.AdminNotes))
                    {
                        <p class="mb-0"><strong>ملاحظات:</strong> @Model.AdminNotes</p>
                    }
                </div>
            }
        </div>
    </div>
</div>

@functions {
    string GetStatusBadge(string status)
    {
        return status switch
        {
            "Pending" => "bg-warning",
            "Approved" => "bg-success",
            "Rejected" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}

@section Styles {
    <style>
        .admin-deposit-details {
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
        }

        .info-item {
            margin-bottom: 1rem;
        }

            .info-item h6 {
                font-size: 0.9rem;
                color: #6c757d;
            }

            .info-item p {
                margin-bottom: 0;
                font-size: 1rem;
            }

        .admin-notes {
            border-right: 4px solid #ffc107;
        }
    </style>
}