@model IEnumerable<SERVE_ME_PROJECT.Models.GeneralSettingsModel>

@{
    ViewData["Title"] = "Index";
    Layout = "_LayoutAdmin";
}

<h1>   معلومات الموقع</h1>


<table class="table">
    <thead style="color:black">
        <tr>
            <th>الاسم             </th>
            <th>الايقونة             </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.SiteName)
            </td>
            <td>>
                    <img src="/img/@item.SiteLogo" height="50"/>
            </td>

                <td>
                    <a asp-action="Edit" class="status-btn success" asp-route-id="@item.Id">تعديل</a> |
                    <a asp-action="Details" class="status-btn waiting" asp-route-id="@item.Id">التفاصيل </a> |
                </td>
        </tr>
}
    </tbody>
</table>
