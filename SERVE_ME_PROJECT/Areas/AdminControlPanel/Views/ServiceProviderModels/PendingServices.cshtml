
@model List<SERVE_ME_PROJECT.Models.ServiceModel>

@{
    Layout = "_LayoutAdmin";
}

<h2 class="mb-4">الخدمات قيد المراجعة</h2>

<!-- نموذج البحث -->
<form method="get" asp-action="PendingServices" class="mb-4">
    <div class="row g-2">
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">بحث</button>
        </div>

        <div class="col-md-4">
            <input type="text" name="searchTerm" value="@(Context.Request.Query["searchTerm"])" 
            class="form-control" placeholder="ابحث عن خدمة أو مزود خدمة..." />
        </div>
        <div class="col-md-2">
            <button class="  btn-primary  " style="width:200px">           
                <a asp-area="AdminControlPanel" asp-controller="ServiceProviderModels" asp-action="Index2"  style="color:white ">عرض جميع الخدمات</a>
             </button>
        </div>
    </div>
</form>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info text-center">
        لا توجد خدمات جديدة حالياً.
    </div>
}
else
{
    <table class="table table-hover text-center">
        <thead>
            <tr>
                <th>العنوان</th>
                <th>مزود الخدمة</th>
                <th>التصنيف</th>
                <th>الإجراءات</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var service in Model)
            {
                <tr>
                    <td>@service.Name</td>
                    <td>@service.User.UserName</td>
                    <td>@service.Category.Name</td>
                    <td>
                        <a href="@Url.Action("DetailsService", "ServiceProviderModels", new { id = service.Id })" class="btn btn-info btn-sm">
                            عرض التفاصيل
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
